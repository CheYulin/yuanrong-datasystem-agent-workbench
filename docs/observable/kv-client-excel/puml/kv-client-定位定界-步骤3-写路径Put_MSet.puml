@startuml kv_client_triage_write_step
skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName "SansSerif"
skinparam sequenceMessageAlign center
skinparam wrapWidth 360

title KV Client 定位定界（步骤3: 写路径 MCreate / MSet(buffer) / Put / MSet(keys,vals)）\n显式：client / w1 / w3 + OS syscall + URMA；可与观测 Excel 定界-case、调用链表对照

actor "测试/开发/Agent" as T
participant "client1\nSDK" as C
participant "worker1\n入口Worker" as W1
participant "worker3\n数据副本" as W3
participant "URMA\n(UMDK/UB)" as U
participant "OS\nsyscall" as OS

T -> C : 发起写请求\n(Put / MSet / MCreate+MSet)
activate C

== 可选: MCreate（Worker 分配 shm / 元数据；Client 再 mmap 写） ==
opt 两阶段: MCreate -> MSet(buffer)
  C -> OS : [Client] RPC 发送 MultiCreate\n(同读路径: sendmsg/write…)
  activate OS
  OS -> W1 : 交付至 W1
  deactivate OS
  activate W1
  W1 -> OS : [W1] recv 取 MultiCreate 请求
  activate OS
  OS --> W1 : 请求体
  deactivate OS

  W1 -> OS : [W1] shm_open/shmget/mmap/\nftruncate 等分配共享内存\n(具体依实现)
  activate OS
  alt 分配失败
    OS --> W1 : ENOSPC / EMFILE …
    note right of W1
      现象: 1001/1002/19
      或 K_IO_ERROR / K_NO_SPACE
    end note
    W1 --> C : MultiCreate 失败
    deactivate W1
    C --> T : MCreate 失败
    deactivate C
    return
  end
  OS --> W1 : fd / 映射信息
  deactivate OS

  W1 -> OS : [W1] send 回包(含 fd 传递描述)\n(UDS scm_rights 时常经 recvmsg/sendmsg)
  activate OS
  OS -> C : 响应到 Client
  deactivate OS
  W1 --> C : Buffer 句柄 / 元数据
  deactivate W1

  C -> OS : [Client] mmap(fd) /\n写入用户数据到 SHM
  activate OS
  alt mmap/memcpy 失败
    C --> T : 客户端资源错误
    deactivate C
    deactivate OS
    return
  end
  deactivate OS
end

note over C, U
  **UB 直发路径**
  Client UrmaWritePayload 与 **W3** urma_write 等
  同属**同一 UB 数据面**时，定界需 **Trace**
  与两端 URMA 日志。
  否则 payload 经 **RPC+OS** 进 W1/W3。
end note

C -> C : 参数校验\n(MSet: 去重、memcpy 等)
alt 参数非法
  C --> T : K_INVALID
  deactivate C
  return
end

== Client: UB 单对象直发（可选；与 W3 URMA 写入关联） ==
opt UB 单对象 payload 路径
  C -> U : [Client] UrmaWritePayload /\nurma_write(UMDK)
  activate U
  alt UB 发送失败
    note right of U
      现象: Failed to send buffer via UB
    end note
    U --> C : 失败
    C -> C : 可切非 UB / 走 RPC
  else 成功
    U --> C : OK
  end
  deactivate U
end

== Client → W1: Publish / MultiPublish（经 OS） ==
C -> OS : [Client] RPC Publish/MultiPublish
activate OS
OS -> W1 : 交付请求
deactivate OS
activate W1

W1 -> OS : [W1] recv / read 请求体
activate OS
OS --> W1 : PublishReq
deactivate OS

alt 1001/1002/19
  W1 --> C : RPC 错误
  deactivate W1
  C --> T : 写失败(RPC)
  deactivate C
  return
else K_SCALING(32) / OOM(6)
  note right of W1
    扩缩容窗口 / 内存水位
  end note
end

== W1 → W3: 数据落副本 ==
W1 -> W3 : 转发写 / 本地持久化
activate W3

opt 落盘 / spill（OS）
  W3 -> OS : [W3] pwrite / fwrite /\nfdatasync 等
  activate OS
  OS --> W3 : IO 结果
  deactivate OS
end

opt URMA 远端/副本数据面（与 Client U 对齐）
  W3 -> U : [W3] urma_write / RDMA 路径 /\npoll jfc / segment 注册
  activate U
  alt URMA 写入/完成失败
    note right of U
      K_URMA_ERROR / 1006 / Runtime
      **同 Trace** 查 W3 + Client URMA 行
    end note
  end
  U --> W3 : completion
  deactivate U
end

W3 --> W1 : 写入结果
deactivate W3

W1 -> OS : [W1] send 写响应
activate OS
OS -> C : 响应
deactivate OS
deactivate W1

== Client: 清理（OS） ==
opt 引用计数 / 关闭映射
  C -> OS : [Client] munmap / close
  note right of OS
    异常时查 fd 泄漏
    double-close
  end note
end

C --> T : 写完成
deactivate C

note bottom
  **写路径 syscall**
  sendmsg/recvmsg, mmap, shm_*, pwrite
  **fd 传递**
  **写路径 URMA**
  Client UrmaWritePayload ↔ W3 urma_write 等
  UB 会话一致时用 Trace 关联
end note

@enduml
