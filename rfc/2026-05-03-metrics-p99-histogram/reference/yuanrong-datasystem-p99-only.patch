+/**
+ * Histogram P99 performance / concurrency smoke (ST cc_test with own main; heavy).
+ *
+ * bazel test //tests/st/common/metrics:histogram_p99_perf_test
+ */
+
+#include "datasystem/common/metrics/metrics.h"
+
+#include <atomic>
+#include <chrono>
+#include <iostream>
+#include <string>
+#include <thread>
+#include <vector>
+
+#include "datasystem/common/flags/flags.h"
+
+DS_DECLARE_bool(log_monitor);
+DS_DECLARE_int32(log_monitor_interval_ms);
+
+constexpr uint16_t HIST_ID = 0;
+const datasystem::metrics::MetricDesc DESCS[] = {
+    { HIST_ID, "perf_histogram", datasystem::metrics::MetricType::HISTOGRAM, "us" },
+};
+
+std::string ExtractField(const std::string &json, const char *field)
+{
+    std::string key = "\"" + std::string(field) + "\":";
+    size_t pos = json.find(key);
+    if (pos == std::string::npos) {
+        return "0";
+    }
+    std::string val = json.substr(pos + key.size());
+    size_t end = val.find_first_of(",}");
+    if (end == std::string::npos) {
+        return "0";
+    }
+    return val.substr(0, end);
+}
+
+int main()
+{
+    FLAGS_log_monitor = false;
+    bool allOk = true;
+
+    const int threads = 16;
+    const int loopsPerThread = 1000000;
+    const uint64_t fixedValue = 100;
+
+    std::cout << "========================================" << std::endl;
+    std::cout << "  Histogram P99 Performance Test" << std::endl;
+    std::cout << "========================================" << std::endl;
+
+    // Test 1: Fixed value (lock contention only)
+    {
+        std::cout << "\n[Test 1] Fixed Value (100us) - Lock Contention" << std::endl;
+        std::cout << "------------------------------------------------" << std::endl;
+
+        datasystem::metrics::ResetForTest();
+        (void)datasystem::metrics::Init(DESCS, sizeof(DESCS) / sizeof(DESCS[0]));
+
+        auto start = std::chrono::high_resolution_clock::now();
+
+        std::vector<std::thread> workers;
+        for (int t = 0; t < threads; ++t) {
+            workers.emplace_back([&] {
+                for (int i = 0; i < loopsPerThread; ++i) {
+                    datasystem::metrics::GetHistogram(HIST_ID).Observe(fixedValue);
+                }
+            });
+        }
+        for (auto &w : workers) {
+            w.join();
+        }
+
+        auto end = std::chrono::high_resolution_clock::now();
+        auto duration = std::chrono::duration_cast<std::chrono::microseconds>(end - start).count();
+        auto totalOps = static_cast<int64_t>(threads) * loopsPerThread;
+        auto nsPerOp = (duration * 1000) / totalOps;
+
+        std::cout << "Threads: " << threads << std::endl;
+        std::cout << "Total ops: " << totalOps << std::endl;
+        std::cout << "Duration: " << duration << " us" << std::endl;
+        std::cout << "Throughput: " << (totalOps * 1000000LL / duration) << " ops/s" << std::endl;
+        std::cout << "Latency: " << nsPerOp << " ns/op" << std::endl;
+
+        auto summary = datasystem::metrics::DumpSummaryForTest();
+        auto count = std::stoull(ExtractField(summary, "count"));
+        auto p99 = std::stoull(ExtractField(summary, "p99"));
+
+        std::cout << "\n[Correctness]" << std::endl;
+        const bool countOk = (count == static_cast<uint64_t>(totalOps));
+        std::cout << "Count: " << count << " (expected " << totalOps << ") - "
+                  << (countOk ? "PASS" : "FAIL") << std::endl;
+        // All samples in (100,200]µs; linear interpolation yields 199 for this n (not 200).
+        const bool p99Ok = (p99 == 199);
+        std::cout << "P99: " << p99 << " (expected 199) - " << (p99Ok ? "PASS" : "FAIL") << std::endl;
+        allOk = allOk && countOk && p99Ok;
+    }
+
+    // Test 2: Random values across buckets
+    {
+        std::cout << "\n[Test 2] Random Values (10/100/1000/10000us)" << std::endl;
+        std::cout << "------------------------------------------------" << std::endl;
+
+        datasystem::metrics::ResetForTest();
+        (void)datasystem::metrics::Init(DESCS, sizeof(DESCS) / sizeof(DESCS[0]));
+
+        std::atomic<int> counter{ 0 };
+        auto start = std::chrono::high_resolution_clock::now();
+
+        std::vector<std::thread> workers;
+        for (int t = 0; t < threads; ++t) {
+            workers.emplace_back([&] {
+                uint64_t values[] = { 10, 100, 1000, 10000 };
+                for (int i = 0; i < loopsPerThread; ++i) {
+                    datasystem::metrics::GetHistogram(HIST_ID).Observe(values[counter.fetch_add(1) % 4]);
+                }
+            });
+        }
+        for (auto &w : workers) {
+            w.join();
+        }
+
+        auto end = std::chrono::high_resolution_clock::now();
+        auto duration = std::chrono::duration_cast<std::chrono::microseconds>(end - start).count();
+        auto totalOps = static_cast<int64_t>(threads) * loopsPerThread;
+        auto nsPerOp = (duration * 1000) / totalOps;
+
+        std::cout << "Threads: " << threads << std::endl;
+        std::cout << "Total ops: " << totalOps << std::endl;
+        std::cout << "Duration: " << duration << " us" << std::endl;
+        std::cout << "Throughput: " << (totalOps * 1000000LL / duration) << " ops/s" << std::endl;
+        std::cout << "Latency: " << nsPerOp << " ns/op" << std::endl;
+
+        auto summary = datasystem::metrics::DumpSummaryForTest();
+        auto p99 = std::stoull(ExtractField(summary, "p99"));
+        std::cout << "\n[Correctness]" << std::endl;
+        // ~25% each in 10/100/1000/10000µs buckets → 99p lands in the 10ms tier,
+        // often interpolated into (10000,20000]µs (e.g. ~19600).
+        const bool bandOk = (p99 >= 10000 && p99 <= 20000);
+        std::cout << "P99: " << p99 << " (expected ~10000..20000) - " << (bandOk ? "PASS" : "FAIL")
+                  << std::endl;
+        allOk = allOk && bandOk;
+    }
+
+    // Test 3: Multi-threaded correctness with known distribution
+    {
+        std::cout << "\n[Test 3] Multi-threaded Correctness (99x10 + 1x10000)" << std::endl;
+        std::cout << "------------------------------------------------" << std::endl;
+
+        datasystem::metrics::ResetForTest();
+        (void)datasystem::metrics::Init(DESCS, sizeof(DESCS) / sizeof(DESCS[0]));
+
+        std::thread t1([&] {
+            for (int i = 0; i < 99; ++i) {
+                datasystem::metrics::GetHistogram(HIST_ID).Observe(10);
+            }
+        });
+        std::thread t2([&] {
+            for (int i = 0; i < 1; ++i) {
+                datasystem::metrics::GetHistogram(HIST_ID).Observe(10000);
+            }
+        });
+        t1.join();
+        t2.join();
+
+        auto summary = datasystem::metrics::DumpSummaryForTest();
+        auto count = std::stoull(ExtractField(summary, "count"));
+        auto p99 = std::stoull(ExtractField(summary, "p99"));
+
+        std::cout << "Distribution: 99x10 + 1x10000" << std::endl;
+        std::cout << "\n[Correctness]" << std::endl;
+        const bool countOk = (count == 100);
+        std::cout << "Count: " << count << " (expected 100) - " << (countOk ? "PASS" : "FAIL")
+                  << std::endl;
+        const bool p99Ok = (p99 == 20);
+        std::cout << "P99: " << p99 << " (expected 20, bucket interpolation in (10,20]) - "
+                  << (p99Ok ? "PASS" : "FAIL") << std::endl;
+        allOk = allOk && countOk && p99Ok;
+    }
+
+    // Test 4: Concurrent observe + dump
+    {
+        std::cout << "\n[Test 4] Concurrent Observe + Dump (Read-Write Race)" << std::endl;
+        std::cout << "------------------------------------------------" << std::endl;
+
+        datasystem::metrics::ResetForTest();
+        (void)datasystem::metrics::Init(DESCS, sizeof(DESCS) / sizeof(DESCS[0]));
+
+        std::atomic<bool> stop{ false };
+        std::atomic<uint64_t> totalObserved{ 0 };
+
+        std::vector<std::thread> writers;
+        for (int t = 0; t < threads; ++t) {
+            writers.emplace_back([&]() {
+                while (!stop.load()) {
+                    datasystem::metrics::GetHistogram(HIST_ID).Observe(100);
+                    totalObserved.fetch_add(1);
+                }
+            });
+        }
+
+        std::atomic<uint64_t> dumpCount{ 0 };
+        std::vector<std::thread> readers;
+        for (int t = 0; t < 4; ++t) {
+            readers.emplace_back([&]() {
+                while (!stop.load()) {
+                    (void)datasystem::metrics::DumpSummaryForTest();
+                    dumpCount.fetch_add(1);
+                }
+            });
+        }
+
+        std::this_thread::sleep_for(std::chrono::seconds(2));
+        stop.store(true);
+        for (auto &w : writers) {
+            w.join();
+        }
+        for (auto &r : readers) {
+            r.join();
+        }
+
+        auto summary = datasystem::metrics::DumpSummaryForTest();
+        auto count = std::stoull(ExtractField(summary, "count"));
+
+        std::cout << "Test duration: 2 seconds" << std::endl;
+        std::cout << "Total observed: " << totalObserved.load() << std::endl;
+        std::cout << "Total dumps: " << dumpCount.load() << std::endl;
+        std::cout << "\n[Correctness]" << std::endl;
+        const bool countLe = (count <= totalObserved.load());
+        std::cout << "Count: " << count << " <= observed: " << (countLe ? "PASS" : "FAIL") << std::endl;
+        std::cout << "No crash: PASS" << std::endl;
+        allOk = allOk && countLe;
+    }
+
+    std::cout << "\n========================================" << std::endl;
+    std::cout << "  All Tests Completed" << (allOk ? "" : " (FAILED)") << std::endl;
+    std::cout << "========================================" << std::endl;
+    return allOk ? 0 : 1;
+}
