# Virtual environments
.venv*/
.venv-fm/

# Python bytecode
*.pyc
__pycache__/

# ── workspace/observability generated artifacts ──
# Raw bpftrace traces (can be >100MB each)
workspace/observability/bpftrace/*_stacks.txt
workspace/observability/bpftrace/*_stacks.sym.txt
# Process memory maps (not useful for AI context)
workspace/observability/bpftrace/*_maps.txt
# PID files
workspace/observability/bpftrace/*.pid
# Chart images (not readable as text)
workspace/observability/perf/*.png

# ── workspace/reliability generated artifacts ──
# Binary Excel files (generated by scripts, not readable by AI)
workspace/reliability/*.xlsx

# ── results/ generated artifacts ──
# Huge test logs (can be >100MB)
results/*/log.txt
# Raw per-iteration test logs
results/*/raw_logs/
# Process exit code files
results/*/exit.code
